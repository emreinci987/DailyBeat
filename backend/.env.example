# =============================================
# DailyBeat — Environment Variables
# =============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================

# ── Server ──
NODE_ENV=development
PORT=3001

# ── Firebase Admin SDK ──
# Option A: path to a service-account JSON key file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option B: individual values (used when the JSON file is not present,
#           e.g. in CI/CD or cloud deployments)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Firebase Web / Client Config (used by frontend) ──
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── External APIs ──
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YOUTUBE_API_KEY=

# ── CORS ──
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
