{
    "name": "dailybeat-backend",
    "version": "1.0.0",
    "description": "DailyBeat API — mood-based music recommendation backend",
    "main": "src/server.js",
    "type": "module",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --forceExit --detectOpenHandles",
        "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=tests/unit --forceExit",
        "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=tests/integration --forceExit --detectOpenHandles",
        "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --forceExit --detectOpenHandles",
        "lint": "eslint src/ tests/"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-rate-limit": "^7.5.0",
        "firebase-admin": "^13.0.2",
        "helmet": "^8.0.0",
        "morgan": "^1.10.0",
        "winston": "^3.17.0",
        "joi": "^17.13.3",
        "compression": "^1.7.5"
    },
    "devDependencies": {
        "@jest/globals": "^29.7.0",
        "cross-env": "^7.0.3",
        "eslint": "^9.17.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.9",
        "supertest": "^7.0.0"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}